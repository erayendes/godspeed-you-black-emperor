---
import "../styles/global.css";

const {
  title = "gybe.org",
  description = "A source-minded Godspeed You! Black Emperor fan archive for records, live dates, members, side projects, and related Montreal paths.",
  image = "/images/site/live-stage.jpg",
  type = "website",
  structuredData = [],
} = Astro.props;

const nav = [
  ["about", "/about/"],
  ["discography", "/disco/"],
  ["shows", "/shows/"],
  ["members", "/members/"],
  ["crossing-paths", "/crossing-paths/"],
  ["contact", "/contact/"],
];

const currentPath = Astro.url.pathname === "/" ? "/" : Astro.url.pathname.replace(/\/?$/, "/");
const gaMeasurementId = "G-TYG1HPB56V";
const siteUrl = Astro.site ?? new URL("https://gybe.org");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const keywords = [
  "Godspeed You! Black Emperor",
  "GY!BE",
  "gybe.org",
  "discography",
  "live dates",
  "Constellation Records",
  "Montreal post-rock",
].join(", ");
const baseStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "gybe.org",
    url: "https://gybe.org/",
    founder: {
      "@type": "Person",
      name: "Eray Endes",
    },
    description: "An unofficial, non-commercial Godspeed You! Black Emperor fan archive.",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "gybe.org",
    url: "https://gybe.org/",
    description: "A source-minded fan archive for Godspeed You! Black Emperor records, live dates, members, side projects, and related Montreal paths.",
    inLanguage: "en",
    isAccessibleForFree: true,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    url: canonicalUrl,
    description,
    inLanguage: "en",
    isAccessibleForFree: true,
    isPartOf: {
      "@type": "WebSite",
      name: "gybe.org",
      url: "https://gybe.org/",
    },
  },
];
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const allStructuredData = [...baseStructuredData, ...pageStructuredData];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="gybe.org" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {allStructuredData.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
    <script is:inline define:vars={{ gaMeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", gaMeasurementId);
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell site-header__inner">
        <div class="wordmark">
          <a href="/">godspeed you! black emperor</a>
          <small>an unofficial non-commercial fan archive</small>
        </div>
        <nav class="nav" aria-label="Primary navigation">
          {nav.map(([label, href]) => (
            <a href={href} aria-current={currentPath === href ? "page" : undefined}>{label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main class="site-shell">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-shell">
        <p>
          gybe.org is maintained by Eray Endes as an unofficial, non-commercial fan archive and is not affiliated with the band, Constellation, Kranky, or any rights holder.
          All names, artwork, and trademarks belong to their owners. No lyrics are hosted here. Buy records and confirm live dates through official sources.{" "}
          <a href="/contact/">Contact</a> for corrections or removal requests.
        </p>
      </div>
    </footer>
  </body>
</html>
