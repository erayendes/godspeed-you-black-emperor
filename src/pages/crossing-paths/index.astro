---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { crossingPaths } from "../../data/crossingPaths";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Godspeed You! Black Emperor crossing paths",
  itemListElement: crossingPaths.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.title,
    url: `https://gybe.org/crossing-paths/${item.slug}/`,
  })),
};
---

<BaseLayout
  title="GY!BE Side Projects and Related Artists / gybe.org"
  description="Side projects, related artists, and scene links around Godspeed You! Black Emperor, Constellation Records, and the Montreal independent music network."
  structuredData={structuredData}
>
  <h1 class="page-title">crossing-paths</h1>
  <p class="deck">
    Side projects, related artists, and scene links around the Godspeed / Constellation / Montreal orbit.
  </p>

  <section class="crossing-list">
    {crossingPaths.map((item) => (
      <article class="crossing-item">
        <a class="crossing-item__title" href={`/crossing-paths/${item.slug}/`}>{item.title}</a>
        <p class="crossing-item__relation">{item.relation}</p>
        <p class="crossing-item__summary">{item.summary}</p>
      </article>
    ))}
  </section>
</BaseLayout>
