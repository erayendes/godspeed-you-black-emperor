---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { crossingPaths } from "../../data/crossingPaths";

export function getStaticPaths() {
  return crossingPaths.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const description = item.summary;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "MusicGroup",
    name: item.title,
    url: `https://gybe.org/crossing-paths/${item.slug}/`,
    description: item.summary,
    subjectOf: {
      "@type": "WebPage",
      url: `https://gybe.org/crossing-paths/${item.slug}/`,
    },
    sameAs: item.links.map((link) => link.url),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://gybe.org/" },
      { "@type": "ListItem", position: 2, name: "Crossing paths", item: "https://gybe.org/crossing-paths/" },
      { "@type": "ListItem", position: 3, name: item.title, item: `https://gybe.org/crossing-paths/${item.slug}/` },
    ],
  },
];
---

<BaseLayout title={`${item.title} | GY!BE Network`} description={description} structuredData={structuredData}>
  <article class="content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">home</a>
      <span>/</span>
      <a href="/crossing-paths/">crossing-paths</a>
      <span>/</span>
      <span>{item.title}</span>
    </nav>
    <p class="meta">{item.relation}</p>
    <h1 class="page-title">{item.title}</h1>
    <p class="deck">{item.summary}</p>

    <h2>profile</h2>
    {item.body.map((paragraph) => <p>{paragraph}</p>)}

    {item.discography.length > 0 && (
      <>
        <h2>selected discography</h2>
        <ul>
          {item.discography.map((release) => <li>{release}</li>)}
        </ul>
      </>
    )}

    {item.links.length > 0 && (
      <>
        <h2>links</h2>
        <div class="link-list">
          {item.links.map((link) => <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>)}
        </div>
      </>
    )}
  </article>
</BaseLayout>
