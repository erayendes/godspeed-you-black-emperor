---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { members } from "../../data/members";
import { crossingPaths } from "../../data/crossingPaths";

export function getStaticPaths() {
  return members.map((member) => ({
    params: { slug: member.slug },
    props: { member },
  }));
}

const { member } = Astro.props;
const description = member.summary;
const related = crossingPaths.filter((item) =>
  member.projects.some((project) => item.title.toLowerCase().includes(project.toLowerCase().replace(/^thee /, "")) || project.toLowerCase().includes(item.title.toLowerCase()))
);
const projectContext = member.projects.length > 0
  ? `Related projects listed here: ${member.projects.join(", ")}. These links place the member inside the wider Montreal and Constellation-adjacent network rather than treating the GY!BE lineup as an isolated roster.`
  : "No related project is currently listed for this archive entry. The page still keeps role and years active visible so the member's place in the band history is clear.";
const archiveContext = `${member.name} is listed as a ${member.status} Godspeed You! Black Emperor member with the role recorded as ${member.role}. The years field is ${member.years}. ${projectContext}`;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: member.name,
    url: `https://gybe.org/members/${member.slug}/`,
    description: member.summary,
    memberOf: {
      "@type": "MusicGroup",
      name: "Godspeed You! Black Emperor",
    },
    hasOccupation: member.role,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://gybe.org/" },
      { "@type": "ListItem", position: 2, name: "Members", item: "https://gybe.org/members/" },
      { "@type": "ListItem", position: 3, name: member.name, item: `https://gybe.org/members/${member.slug}/` },
    ],
  },
];
---

<BaseLayout title={`${member.name} | GY!BE Member`} description={description} structuredData={structuredData}>
  <article class="content">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">home</a>
      <span>/</span>
      <a href="/members/">members</a>
      <span>/</span>
      <span>{member.name}</span>
    </nav>
    <p class="meta">{member.status} / {member.years}</p>
    <h1 class="page-title">{member.name}</h1>
    <p class="deck">{member.summary}</p>

    <h2>archive context</h2>
    <p>{archiveContext}</p>

    {member.bio && (
      <>
        <h2>biography</h2>
        {member.bio.map((paragraph) => <p>{paragraph}</p>)}
      </>
    )}

    <h2>role</h2>
    <table class="status-table">
      <tbody>
        <tr><th>instrument / work</th><td>{member.role}</td></tr>
        <tr><th>years</th><td>{member.years}</td></tr>
        <tr><th>status</th><td>{member.status}</td></tr>
      </tbody>
    </table>

    {member.projects.length > 0 && (
      <>
        <h2>crossing paths</h2>
        <ul>
          {member.projects.map((project) => {
            const match = related.find((item) => item.title.toLowerCase().includes(project.toLowerCase().replace(/^thee /, "")) || project.toLowerCase().includes(item.title.toLowerCase()));
            return <li>{match ? <a href={`/crossing-paths/${match.slug}/`}>{project}</a> : project}</li>;
          })}
        </ul>
      </>
    )}
  </article>
</BaseLayout>
