---
import BaseLayout from "../layouts/BaseLayout.astro";
import { shows } from "../data/shows";

const structuredData = shows.dates.map((show) => ({
  "@context": "https://schema.org",
  "@type": "MusicEvent",
  name: `Godspeed You! Black Emperor - ${show.city}`,
  startDate: show.date,
  url: show.ticketUrl,
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  eventStatus: "https://schema.org/EventScheduled",
  performer: {
    "@type": "MusicGroup",
    name: "Godspeed You! Black Emperor",
  },
  location: {
    "@type": "Place",
    name: show.venue,
    address: {
      "@type": "PostalAddress",
      addressLocality: show.city,
      addressCountry: show.country,
    },
  },
}));
---

<BaseLayout
  title="Godspeed You! Black Emperor Live Dates / gybe.org"
  description="Current Godspeed You! Black Emperor live dates copied from Constellation Live, manually reviewed, and linked to official ticket or source pages."
  structuredData={structuredData}
>
  <h1 class="page-title">shows</h1>
  <p class="deck">
    Current dates are manually copied from the official label source. This keeps the page static, reviewable, and free to host.
  </p>

  <section class="content">
    <p class="side-note">
      Source: <a href={shows.sourceUrl} target="_blank" rel="noopener noreferrer">{shows.source}</a><br />
      Last checked: {shows.lastChecked}<br />
      Update mode: {shows.updateMode}
    </p>
  </section>

  <section>
    <h2 class="section-title">upcoming</h2>
    <table class="status-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>City</th>
          <th>Venue / festival</th>
          <th>Link</th>
        </tr>
      </thead>
      <tbody>
        {shows.dates.map((show) => (
          <tr>
            <td>{show.displayDate}</td>
            <td>{show.city}, {show.country}</td>
            <td>{show.venue}</td>
            <td><a href={show.ticketUrl} target="_blank" rel="noopener noreferrer">ticket/source</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
